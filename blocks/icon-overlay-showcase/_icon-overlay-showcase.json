{
  "definitions": [
    {
      "title": "Icon Overlay Showcase",
      "id": "icon-overlay-showcase",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block", "template": { "name": "Icon Overlay Showcase", "model": "icon-overlay-showcase", "filter": "icon-overlay-showcase", "classes": ["light", "space-small"] } } } }
    },
    {
      "title": "Overlay Panel",
      "id": "overlay-panel",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Overlay Panel", "model": "overlay-panel", "filter": "overlay-panel" } } } }
    },
    {
      "title": "Overlay Hotspot",
      "id": "overlay-hotspot",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Overlay Hotspot", "model": "overlay-hotspot", "x": 50, "y": 50 } } } }
    }
  ],
  "models": [
    {
      "id": "icon-overlay-showcase",
      "fields": [
        { "component": "text", "name": "id", "label": "ID", "description": "Optional page anchor", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Desktop Title", "valueType": "string" },
        { "component": "text", "name": "mobileTitle", "label": "Mobile Title Override", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Style",
          "valueType": "string",
          "maxSize": 2,
          "options": [
            { "name": "Theme", "children": [{ "name": "Light", "value": "light" }, { "name": "Dark", "value": "dark" }, { "name": "Gray", "value": "gray" }] },
            { "name": "Spacing", "children": [{ "name": "Large", "value": "space-large" }, { "name": "Small", "value": "space-small" }, { "name": "None", "value": "space-none" }] }
          ]
        }
      ]
    },
    {
      "id": "overlay-panel",
      "fields": [
        { "component": "text", "name": "panelKey", "label": "Panel Key", "description": "Unique stable key", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Panel Title", "valueType": "string", "required": true },
        { "component": "richtext", "name": "description", "label": "Panel Description", "valueType": "string" },
        { "component": "reference", "name": "image", "label": "Desktop Background", "valueType": "string", "multi": false },
        { "component": "text", "name": "imageAlt", "label": "Desktop Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mobileImage", "label": "Mobile Background", "valueType": "string", "multi": false },
        { "component": "text", "name": "mobileImageAlt", "label": "Mobile Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mask", "label": "Desktop Mask", "valueType": "string", "multi": false },
        { "component": "reference", "name": "mobileMask", "label": "Mobile Mask", "valueType": "string", "multi": false },
        { "component": "text", "name": "maskAlt", "label": "Mask Alt Text", "valueType": "string" }
      ]
    },
    {
      "id": "overlay-hotspot",
      "fields": [
        { "component": "text", "name": "label", "label": "Label", "valueType": "string", "required": true },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        { "component": "reference", "name": "icon", "label": "Icon", "valueType": "string", "multi": false },
        { "component": "text", "name": "iconAlt", "label": "Icon Alt Text", "valueType": "string" },
        { "component": "number", "name": "x", "label": "Desktop X (%)", "valueType": "number", "value": 50, "validation": { "numberMin": 0, "numberMax": 100, "customErrorMsg": "Use a percentage from 0 to 100" } },
        { "component": "number", "name": "y", "label": "Desktop Y (%)", "valueType": "number", "value": 50, "validation": { "numberMin": 0, "numberMax": 100, "customErrorMsg": "Use a percentage from 0 to 100" } },
        { "component": "number", "name": "mobileX", "label": "Mobile X (%)", "valueType": "number", "validation": { "numberMin": 0, "numberMax": 100, "customErrorMsg": "Use a percentage from 0 to 100" } },
        { "component": "number", "name": "mobileY", "label": "Mobile Y (%)", "valueType": "number", "validation": { "numberMin": 0, "numberMax": 100, "customErrorMsg": "Use a percentage from 0 to 100" } }
      ]
    }
  ],
  "filters": [{ "id": "icon-overlay-showcase", "components": ["overlay-panel"] }, { "id": "overlay-panel", "components": ["overlay-hotspot"] }]
}
