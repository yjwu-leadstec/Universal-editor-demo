{
  "definitions": [
    {
      "title": "Header Navigation",
      "id": "header-navigation",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Header Navigation",
              "model": "header-navigation",
              "filter": "header-navigation"
            }
          }
        }
      }
    },
    {
      "title": "Main Navigation Link",
      "id": "header-navigation-top",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Main Navigation Link",
              "model": "header-navigation-top"
            }
          }
        }
      }
    },
    {
      "title": "Dropdown Section Heading",
      "id": "header-navigation-group",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Dropdown Section Heading",
              "model": "header-navigation-group"
            }
          }
        }
      }
    },
    {
      "title": "Dropdown Link Card",
      "id": "header-navigation-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Dropdown Link Card",
              "model": "header-navigation-card"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "header-navigation",
      "fields": [
        {
          "component": "text",
          "name": "cardActionLabel",
          "label": "Shared Card Action Text",
          "description": "One action label shared by every dropdown card in this language, for example Learn More",
          "value": "Learn More",
          "valueType": "string"
        }
      ]
    },
    {
      "id": "header-navigation-top",
      "fields": [
        {
          "component": "text",
          "name": "label",
          "label": "Link Text",
          "description": "Text shown in the main navigation bar",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "destination",
          "label": "Target Page or URL",
          "description": "For an internal link, use the folder button and choose a page under demo-site. You may also enter a complete external HTTPS URL.",
          "valueType": "string",
          "required": true,
          "validation": {
            "rootPath": "/content/demo-site"
          }
        }
      ]
    },
    {
      "id": "header-navigation-group",
      "fields": [
        {
          "component": "text",
          "name": "label",
          "label": "Section Heading",
          "description": "Heading shown above a group of dropdown cards",
          "valueType": "string"
        }
      ]
    },
    {
      "id": "header-navigation-card",
      "fields": [
        {
          "component": "text",
          "name": "label",
          "label": "Link Card Title",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "destination",
          "label": "Target Page or URL",
          "description": "For an internal link, use the folder button and choose a page under demo-site. You may also enter a complete external HTTPS URL.",
          "valueType": "string",
          "required": true,
          "validation": {
            "rootPath": "/content/demo-site"
          }
        },
        {
          "component": "reference",
          "name": "backgroundImage",
          "label": "Card Background Image",
          "description": "Select the DAM image used as the card background",
          "valueType": "string"
        },
        {
          "component": "reference",
          "name": "logoImage",
          "label": "Vehicle Logo Image",
          "description": "Optionally select a transparent PNG vehicle logo or wordmark",
          "valueType": "string"
        },
        {
          "component": "textarea",
          "name": "description",
          "label": "Short Description",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "header-navigation",
      "components": [
        "header-navigation-top",
        "header-navigation-group",
        "header-navigation-card"
      ]
    }
  ]
}
