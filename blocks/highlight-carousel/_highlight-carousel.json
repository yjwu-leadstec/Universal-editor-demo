{
  "definitions": [
    {
      "title": "Highlight Carousel",
      "id": "highlight-carousel",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block", "template": { "name": "Highlight Carousel", "model": "highlight-carousel", "filter": "highlight-carousel", "autoPlay": true, "interval": 4, "showProgress": true, "classes": ["light", "space-small"] } } } }
    },
    {
      "title": "Highlight Slide",
      "id": "highlight-slide",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Highlight Slide", "model": "highlight-slide" } } } }
    }
  ],
  "models": [
    {
      "id": "highlight-carousel",
      "fields": [
        { "component": "text", "name": "id", "label": "ID", "description": "Optional page anchor", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Title", "valueType": "string" },
        { "component": "text", "name": "mobileTitle", "label": "Mobile Title Override", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        { "component": "boolean", "name": "autoPlay", "label": "Desktop Autoplay", "description": "Mobile is always manual", "valueType": "boolean", "value": true },
        { "component": "number", "name": "interval", "label": "Autoplay Interval (seconds)", "valueType": "number", "value": 4, "validation": { "numberMin": 2, "numberMax": 12, "customErrorMsg": "Use an interval from 2 to 12 seconds" } },
        { "component": "boolean", "name": "showProgress", "label": "Show Progress", "valueType": "boolean", "value": true },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Style",
          "valueType": "string",
          "maxSize": 2,
          "options": [
            { "name": "Theme", "children": [{ "name": "Light", "value": "light" }, { "name": "Dark", "value": "dark" }, { "name": "Gray", "value": "gray" }] },
            { "name": "Spacing", "children": [{ "name": "Large", "value": "space-large" }, { "name": "Small", "value": "space-small" }, { "name": "None", "value": "space-none" }] }
          ]
        }
      ]
    },
    {
      "id": "highlight-slide",
      "fields": [
        { "component": "reference", "name": "image", "label": "Desktop Poster / Image", "valueType": "string", "multi": false },
        { "component": "text", "name": "imageAlt", "label": "Desktop Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mobileImage", "label": "Mobile Poster / Image", "valueType": "string", "multi": false },
        { "component": "text", "name": "mobileImageAlt", "label": "Mobile Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "video", "label": "Desktop Video", "valueType": "string", "multi": false },
        { "component": "reference", "name": "mobileVideo", "label": "Mobile Video", "valueType": "string", "multi": false },
        { "component": "text", "name": "eyebrow", "label": "Eyebrow", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Card Title", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Card Description", "valueType": "string" },
        { "component": "text", "name": "note", "label": "Note", "valueType": "string" },
        { "component": "text", "name": "metricValue", "label": "Metric Value", "valueType": "string" },
        { "component": "text", "name": "metricUnit", "label": "Metric Unit", "valueType": "string" },
        { "component": "text", "name": "metricLabel", "label": "Metric Label", "valueType": "string" },
        { "component": "aem-content", "name": "link", "label": "Link", "valueType": "string" },
        { "component": "text", "name": "linkText", "label": "Link Text", "valueType": "string" },
        { "component": "select", "name": "linkType", "label": "Link Type", "valueType": "string", "options": [{ "name": "Text", "value": "text" }, { "name": "Primary", "value": "primary" }, { "name": "Secondary", "value": "secondary" }] }
      ]
    }
  ],
  "filters": [{ "id": "highlight-carousel", "components": ["highlight-slide"] }]
}
