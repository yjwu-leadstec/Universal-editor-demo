      "id": "product-download",
      "fields": [
        { "component": "text", "name": "id", "label": "ID", "description": "Optional page anchor", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Title", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        { "component": "reference", "name": "image", "label": "Desktop Background", "valueType": "string", "multi": false },
        { "component": "text", "name": "imageAlt", "label": "Desktop Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mobileImage", "label": "Mobile Background", "valueType": "string", "multi": false },
        { "component": "text", "name": "mobileImageAlt", "label": "Mobile Image Alt Text", "valueType": "string" },
        { "component": "aem-content", "name": "iosLink", "label": "iOS App Store Link", "valueType": "string" },
        { "component": "text", "name": "iosLinkText", "label": "iOS Link Text", "valueType": "string", "value": "Download on the App Store" },
        { "component": "select", "name": "iosLinkType", "label": "iOS Link Type", "valueType": "string", "value": "primary", "options": [{ "name": "Primary", "value": "primary" }, { "name": "Secondary", "value": "secondary" }, { "name": "Text", "value": "text" }] },
        { "component": "aem-content", "name": "androidLink", "label": "Android Download Link", "valueType": "string" },
        { "component": "text", "name": "androidLinkText", "label": "Android Link Text", "valueType": "string", "value": "Download for Android" },
        { "component": "select", "name": "androidLinkType", "label": "Android Link Type", "valueType": "string", "value": "secondary", "options": [{ "name": "Secondary", "value": "secondary" }, { "name": "Primary", "value": "primary" }, { "name": "Text", "value": "text" }] },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Style",
          "valueType": "string",
          "maxSize": 2,
          "options": [
            { "name": "Theme", "children": [{ "name": "Light", "value": "light" }, { "name": "Dark", "value": "dark" }, { "name": "Gray", "value": "gray" }] },
            { "name": "Copy", "children": [{ "name": "Light", "value": "light-copy" }, { "name": "Dark", "value": "dark-copy" }] }
          ]
        }
      ]
    }
  ],
  "filters": []
