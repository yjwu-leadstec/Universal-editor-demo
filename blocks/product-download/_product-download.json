{
  "definitions": [
    {
      "title": "Product Download",
      "id": "product-download",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block", "template": { "name": "Product Download", "model": "product-download", "iosLinkType": "primary", "androidLinkType": "secondary", "classes": ["dark", "light-copy"] } } } }
    }
  ],
  "models": [
