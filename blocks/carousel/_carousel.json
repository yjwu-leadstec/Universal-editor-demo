{
  "definitions": [
    {
      "title": "Li Carousel",
      "id": "carousel",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Carousel",
              "model": "carousel",
              "filter": "carousel"
            }
          }
        }
      }
    },
    {
      "title": "Li Slide",
      "id": "slide",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Slide",
              "model": "slide"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "carousel",
      "fields": [
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Options",
          "description": "Carousel behavior and navigation options",
          "valueType": "string",
          "options": [
            {
              "name": "Autoplay",
              "children": [
                { "name": "Auto Play On", "value": "auto-play" },
                { "name": "No Loop", "value": "no-loop" }
              ]
            },
            {
              "name": "Transition",
              "children": [
                { "name": "Fade", "value": "fade" },
                { "name": "No Transition", "value": "no-transition" }
              ]
            },
            {
              "name": "Navigation",
              "children": [
                { "name": "Hide Arrows", "value": "hide-arrows" },
                { "name": "Hide Dots", "value": "hide-dots" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "slide",
      "fields": [
        {
          "component": "select",
          "name": "mediaKind",
          "label": "Media Type",
          "description": "Choose between image or video background",
          "value": "image",
          "valueType": "string",
          "options": [
            { "name": "Image", "value": "image" },
            { "name": "Video", "value": "video" }
          ]
        },
        {
          "component": "reference",
          "valueType": "string",
          "name": "image",
          "label": "Image",
          "multi": false,
          "condition": { "===": [{ "var": "mediaKind" }, "image"] }
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "description": "Alternative text for accessibility",
          "valueType": "string",
          "condition": { "===": [{ "var": "mediaKind" }, "image"] }
        },
        {
          "component": "aem-content",
          "name": "video",
          "label": "Video",
          "description": "Video asset from DAM or external URL",
          "valueType": "string",
          "condition": { "===": [{ "var": "mediaKind" }, "video"] }
        },
        {
          "component": "reference",
          "name": "videoPoster",
          "label": "Video Poster Image",
          "description": "Thumbnail shown before video plays",
          "valueType": "string",
          "multi": false,
          "condition": { "===": [{ "var": "mediaKind" }, "video"] }
        },
        {
          "component": "reference",
          "name": "logo",
          "label": "Logo Image",
          "description": "Brand logo overlaid on the slide (transparent PNG recommended)",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "richtext",
          "name": "text",
          "value": "",
          "label": "Text",
          "valueType": "string"
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "CTA Link",
          "description": "Optional call-to-action button link",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "CTA Button Text",
          "description": "Text displayed on the CTA button",
          "value": "",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "carousel",
      "components": [
        "slide"
      ]
    }
  ]
}
