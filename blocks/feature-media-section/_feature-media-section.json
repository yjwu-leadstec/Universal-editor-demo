{
  "definitions": [
    {
      "title": "Feature Media Section",
      "id": "feature-media-section",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block", "template": { "name": "Feature Media Section", "model": "feature-media-section", "filter": "feature-media-section", "variant": "default", "autoPlay": true, "interval": 4, "showVideoControl": true, "showProgress": true, "enableMotion": true, "classes": ["light", "dark-copy", "space-small", "ratio-16-9"] } } } }
    },
    {
      "title": "Feature Media Item",
      "id": "feature-media-item",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Feature Media Item", "model": "feature-media-item", "linkType": "text" } } } }
    },
    {
      "title": "Feature Stat Item",
      "id": "feature-stat-item",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Feature Stat Item", "model": "feature-stat-item" } } } }
    }
  ],
  "models": [
    {
      "id": "feature-media-section",
      "fields": [
        { "component": "text", "name": "id", "label": "ID", "description": "Optional page anchor", "valueType": "string" },
        { "component": "text", "name": "eyebrow", "label": "Eyebrow", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Desktop Title", "valueType": "string" },
        { "component": "text", "name": "mobileTitle", "label": "Mobile Title Override", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        {
          "component": "select",
          "name": "variant",
          "label": "Layout",
          "valueType": "string",
          "value": "default",
          "options": [
            { "name": "Default Tabs", "value": "default" },
            { "name": "Overview", "value": "overview" },
            { "name": "Three Up", "value": "three-up" },
            { "name": "Image Grid", "value": "image-grid" },
            { "name": "Expandable", "value": "expandable" },
            { "name": "Primary Metric", "value": "primary-metric" },
            { "name": "Statistics", "value": "stat" },
            { "name": "Overlay Tabs", "value": "overlay-tabs" }
          ]
        },
        { "component": "boolean", "name": "autoPlay", "label": "Autoplay Tabs", "valueType": "boolean", "value": true },
        { "component": "number", "name": "interval", "label": "Autoplay Interval (seconds)", "valueType": "number", "value": 4, "validation": { "numberMin": 2, "numberMax": 12, "customErrorMsg": "Use an interval from 2 to 12 seconds" } },
        { "component": "boolean", "name": "showVideoControl", "label": "Show Video Control", "valueType": "boolean", "value": true },
        { "component": "boolean", "name": "showProgress", "label": "Show Video Progress", "valueType": "boolean", "value": true },
        { "component": "boolean", "name": "enableMotion", "label": "Enable Reveal / Parallax Motion", "valueType": "boolean", "value": true },
        { "component": "text", "name": "openLabel", "label": "Expandable Open Label", "valueType": "string", "value": "View More" },
        { "component": "text", "name": "closeLabel", "label": "Expandable Close Label", "valueType": "string", "value": "View Less" },
        { "component": "text", "name": "accentColor", "label": "Indicator Color", "description": "Hex color, for example #dbad76", "valueType": "string", "value": "#dbad76", "validation": { "regExp": "^#[0-9a-fA-F]{6}$", "customErrorMsg": "Enter a six-digit hex color such as #dbad76" } },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Style",
          "valueType": "string",
          "maxSize": 4,
          "options": [
            { "name": "Theme", "children": [{ "name": "Light", "value": "light" }, { "name": "Dark", "value": "dark" }, { "name": "Gray", "value": "gray" }] },
            { "name": "Copy", "children": [{ "name": "Light", "value": "light-copy" }, { "name": "Dark", "value": "dark-copy" }] },
            { "name": "Spacing", "children": [{ "name": "Large", "value": "space-large" }, { "name": "Small", "value": "space-small" }, { "name": "None", "value": "space-none" }] },
            { "name": "Media Ratio", "children": [{ "name": "16:9", "value": "ratio-16-9" }, { "name": "2.35:1", "value": "ratio-235-100" }, { "name": "4:3", "value": "ratio-4-3" }] }
          ]
        }
      ]
    },
    {
      "id": "feature-media-item",
      "fields": [
        { "component": "reference", "name": "image", "label": "Desktop Poster / Image", "valueType": "string", "multi": false },
        { "component": "text", "name": "imageAlt", "label": "Desktop Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mobileImage", "label": "Mobile Poster / Image", "valueType": "string", "multi": false },
        { "component": "text", "name": "mobileImageAlt", "label": "Mobile Image Alt Text", "valueType": "string" },
        { "component": "aem-content", "name": "video", "label": "Desktop Video URL", "valueType": "string" },
        { "component": "aem-content", "name": "mobileVideo", "label": "Mobile Video URL", "valueType": "string" },
        { "component": "text", "name": "eyebrow", "label": "Eyebrow / Tab Label", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Title", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" },
        { "component": "text", "name": "note", "label": "Note", "valueType": "string" },
        { "component": "text", "name": "primaryValue", "label": "Primary Metric Value", "valueType": "string" },
        { "component": "text", "name": "primaryUnit", "label": "Primary Metric Unit", "valueType": "string" },
        { "component": "text", "name": "primaryLabel", "label": "Primary Metric Label", "valueType": "string" },
        { "component": "aem-content", "name": "link", "label": "Link", "valueType": "string" },
        { "component": "text", "name": "linkText", "label": "Link Text", "valueType": "string" },
        { "component": "select", "name": "linkType", "label": "Link Type", "valueType": "string", "value": "text", "options": [{ "name": "Text", "value": "text" }, { "name": "Primary", "value": "primary" }, { "name": "Secondary", "value": "secondary" }] }
      ]
    },
    {
      "id": "feature-stat-item",
      "fields": [
        { "component": "text", "name": "value", "label": "Value", "valueType": "string", "required": true },
        { "component": "text", "name": "unit", "label": "Unit", "valueType": "string" },
        { "component": "text", "name": "label", "label": "Label", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Description", "valueType": "string" }
      ]
    }
  ],
  "filters": [{ "id": "feature-media-section", "components": ["feature-media-item", "feature-stat-item"] }]
}
