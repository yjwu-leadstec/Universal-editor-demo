          "description": "响应式显隐选项",
          "valueType": "string",
          "options": [
            {
              "name": "Responsive",
              "children": [
                { "name": "Hide large tile on mobile", "value": "hide-large-mobile" }
              ]
            },
            {
              "name": "Artwork",
              "children": [
                { "name": "Light card artwork", "value": "light-cards" }
              ]
            }
          ]
        },
        {
          "component": "text",
          "name": "id",
          "label": "ID",
          "description": "页内锚点/自动化定位（可选）",
          "valueType": "string"
        }
      ]
    },
    {
      "id": "vehicle-tile",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Background Image",
          "description": "卡片背景图（大卡 960×540、小卡 480×540）",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "valueType": "string"
        },
        {
          "component": "reference",
          "name": "mobileImage",
          "label": "Mobile Background Image",
          "description": "移动端专用背景图（可选）；缺省时使用桌面背景图",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "text",
          "name": "mobileImageAlt",
          "label": "Mobile Image Alt Text",
          "valueType": "string"
        },
        {
          "component": "reference",
          "name": "logo",
          "label": "Vehicle Logo",
          "description": "车型 Logo 字标（透明 PNG）；缺省时显示车型名文本",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "text",
          "name": "vehicleName",
          "label": "Vehicle Name",
          "description": "如 Li i6、Li L9",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "subtitle",
          "label": "Subtitle",
          "description": "如 New-Form 5-Seat SUV",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "size",
          "label": "Card Size",
          "description": "large 卡片跨 2 列（用于首张大卡）",
          "value": "small",
          "valueType": "string",
          "options": [
            { "name": "Small (1 column)", "value": "small" },
            { "name": "Large (2 columns)", "value": "large" }
          ]
        },
        {
          "component": "select",
          "name": "kind",
          "label": "Tile Kind",
          "description": "Charging 为充电促销卡（文案底部对齐，仅一个 CTA）",
          "value": "vehicle",
          "valueType": "string",
          "options": [
            { "name": "Vehicle", "value": "vehicle" },
            { "name": "Charging Promo", "value": "charging" }
          ]
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Link",
          "description": "车型详情页链接",
          "valueType": "string"
