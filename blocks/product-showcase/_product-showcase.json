{
  "definitions": [
    {
      "title": "Li Product Showcase",
      "id": "product-showcase",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Product Showcase",
              "model": "product-showcase",
              "filter": "product-showcase"
            }
          }
        }
      }
    },
    {
      "title": "Li Product Card",
      "id": "product-card",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block/item",
            "template": {
              "name": "Product Card",
              "model": "product-card"
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "product-showcase",
      "fields": [
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Theme",
          "description": "Visual theme for the showcase grid",
          "valueType": "string",
          "options": [
            {
              "name": "Theme",
              "children": [
                { "name": "Light", "value": "light" },
                { "name": "Dark", "value": "dark" }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "product-card",
      "fields": [
        {
          "component": "reference",
          "name": "image",
          "label": "Background Image",
          "description": "Full-bleed background image for the card",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "text",
          "name": "imageAlt",
          "label": "Image Alt Text",
          "valueType": "string"
        },
        {
          "component": "reference",
          "name": "logo",
          "label": "Product Logo",
          "description": "Brand logo image overlaid on the card (transparent PNG recommended)",
          "valueType": "string",
          "multi": false
        },
        {
          "component": "text",
          "name": "productName",
          "label": "Product Name",
          "description": "e.g. Li i6, Li L9",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "subtitle",
          "label": "Subtitle",
          "description": "Short description, e.g. 'Luxury 5-Seat Family SUV'",
          "valueType": "string"
        },
        {
          "component": "select",
          "name": "size",
          "label": "Card Size",
          "description": "Big cards span 2 columns in the grid",
          "value": "small",
          "valueType": "string",
          "options": [
            { "name": "Small (1 column)", "value": "small" },
            { "name": "Big (2 columns)", "value": "big" }
          ]
        },
        {
          "component": "aem-content",
          "name": "link",
          "label": "Product Page Link",
          "valueType": "string"
        },
        {
          "component": "text",
          "name": "linkText",
          "label": "CTA Text",
          "description": "Button text, e.g. 'Learn More'",
          "value": "Learn More",
          "valueType": "string"
        }
      ]
    }
  ],
  "filters": [
    {
      "id": "product-showcase",
      "components": [
        "product-card"
      ]
    }
  ]
}
