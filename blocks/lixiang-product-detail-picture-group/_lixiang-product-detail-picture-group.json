{
  "definitions": [
    {
      "title": "Li Xiang Product Detail Picture Group",
      "id": "lixiang-product-detail-picture-group",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block", "template": { "name": "Lixiang Product Detail Picture Group", "model": "lixiang-product-detail-picture-group", "filter": "lixiang-product-detail-picture-group", "showVideoControl": true, "showProgress": true, "enableMotion": true, "classes": ["light", "space-large", "picture-gap-large"] } } } }
    },
    {
      "title": "Li Xiang Product Detail Picture Set",
      "id": "lixiang-product-detail-picture-group-item",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Lixiang Product Detail Picture Set", "model": "lixiang-product-detail-picture-group-item", "filter": "lixiang-product-detail-picture-group-item" } } } }
    },
    {
      "title": "Li Xiang Product Detail Picture",
      "id": "lixiang-product-detail-picture-item",
      "plugins": { "xwalk": { "page": { "resourceType": "core/franklin/components/block/v1/block/item", "template": { "name": "Lixiang Product Detail Picture", "model": "lixiang-product-detail-picture-item" } } } }
    }
  ],
  "models": [
    {
      "id": "lixiang-product-detail-picture-group",
      "fields": [
        { "component": "text", "name": "id", "label": "ID", "description": "Optional page anchor", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Desktop / Tablet Title", "description": "Automatically wraps; hidden below 720px to match the approved mobile layout", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Desktop / Tablet Description", "valueType": "string" },
        { "component": "boolean", "name": "showVideoControl", "label": "Show Video Controls", "valueType": "boolean", "value": true },
        { "component": "boolean", "name": "showProgress", "label": "Show Video Progress", "valueType": "boolean", "value": true },
        { "component": "boolean", "name": "enableMotion", "label": "Enable Image Parallax", "description": "Automatically disabled when reduced motion is requested", "valueType": "boolean", "value": true },
        {
          "component": "multiselect",
          "name": "classes",
          "label": "Design Style",
          "valueType": "string",
          "maxSize": 3,
          "options": [
            { "name": "Background", "children": [{ "name": "White", "value": "light" }, { "name": "Gray", "value": "gray" }] },
            { "name": "Outer Spacing", "children": [{ "name": "Large (PC 160px / Tablet 64px / Mobile 80px)", "value": "space-large" }, { "name": "Small (PC 80px / Tablet 32px / Mobile 40px)", "value": "space-small" }, { "name": "None (0px)", "value": "space-none" }] },
            { "name": "Title-to-Pictures Gap", "children": [{ "name": "Large (PC 80px / Tablet 24px)", "value": "picture-gap-large" }, { "name": "Small (PC 56px / Tablet 16px)", "value": "picture-gap-small" }] }
          ]
        }
      ]
    },
    {
      "id": "lixiang-product-detail-picture-group-item",
      "fields": [
        { "component": "text", "name": "groupKey", "label": "Picture Set Key", "description": "Unique stable authoring key", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Picture Set / Tab Label", "description": "Only rendered as a tab when more than one set is authored", "valueType": "string", "required": true },
        { "component": "richtext", "name": "description", "label": "Optional Set Description", "valueType": "string" }
      ]
    },
    {
      "id": "lixiang-product-detail-picture-item",
      "fields": [
        { "component": "reference", "name": "image", "label": "Desktop / Tablet Image (use 1.4× source)", "valueType": "string", "multi": false },
        { "component": "text", "name": "imageAlt", "label": "Desktop / Tablet Image Alt Text", "valueType": "string" },
        { "component": "reference", "name": "mobileImage", "label": "Mobile Image (optional crop)", "valueType": "string", "multi": false },
        { "component": "text", "name": "mobileImageAlt", "label": "Mobile Image Alt Text", "valueType": "string" },
        { "component": "aem-content", "name": "video", "label": "Desktop / Tablet Video", "valueType": "string" },
        { "component": "aem-content", "name": "mobileVideo", "label": "Mobile Video", "valueType": "string" },
        { "component": "text", "name": "title", "label": "Picture Caption", "valueType": "string" },
        { "component": "richtext", "name": "description", "label": "Picture Caption Detail", "valueType": "string" }
      ]
    }
  ],
  "filters": [
    {
      "id": "lixiang-product-detail-picture-group",
      "components": [
        "lixiang-product-detail-picture-group-item",
        "lixiang-product-detail-picture-item"
      ]
    }
  ]
}
