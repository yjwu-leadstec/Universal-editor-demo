  {
    "id": "carousel",
    "fields": [
      {
        "component": "boolean",
        "name": "autoPlay",
        "label": "Auto Play",
        "description": "Enable automatic slide rotation",
        "value": true,
        "valueType": "boolean"
      },
      {
        "component": "number",
        "name": "autoPlayInterval",
        "label": "Auto Play Interval (ms)",
        "description": "Time between automatic slide changes",
        "value": 5000,
        "valueType": "number"
      },
      {
        "component": "boolean",
        "name": "loop",
        "label": "Loop",
        "description": "Enable infinite loop playback",
        "value": true,
        "valueType": "boolean"
      },
      {
        "component": "select",
        "name": "transition",
        "label": "Transition Effect",
        "description": "Animation type for slide transitions",
        "value": "slide",
        "valueType": "string",
        "options": [
          {
            "name": "Slide",
            "value": "slide"
          },
          {
            "name": "Fade",
            "value": "fade"
          },
          {
            "name": "None",
            "value": "none"
          }
        ]
      },
      {
        "component": "boolean",
        "name": "showArrows",
        "label": "Show Navigation Arrows",
        "description": "Display prev/next arrow buttons",
        "value": true,
        "valueType": "boolean"
      },
      {
        "component": "boolean",
        "name": "showDots",
        "label": "Show Dot Indicators",
        "description": "Display slide position dots",
        "value": true,
        "valueType": "boolean"
      }
    ]
  },
  {
    "id": "slide",
