          "===": [
            {
              "var": "mediaKind"
            },
            "image"
          ]
        }
      },
      {
        "component": "aem-content",
        "name": "video",
        "label": "Video",
        "description": "Video asset from DAM or external URL",
        "valueType": "string",
        "condition": {
          "===": [
            {
              "var": "mediaKind"
            },
            "video"
          ]
        }
      },
