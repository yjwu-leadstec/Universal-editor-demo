      {
        "component": "reference",
        "valueType": "string",
        "name": "image",
        "label": "Image",
        "multi": false,
        "condition": {
          "===": [
            {
              "var": "mediaKind"
            },
            "image"
          ]
        }
      },
      {
        "component": "text",
        "name": "imageAlt",
        "label": "Image Alt Text",
        "description": "Alternative text for accessibility",
